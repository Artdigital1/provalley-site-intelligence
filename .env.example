# ─────────────────────────────────────────────────────────────
#  ProValley Site Intelligence — Environment Variables
# ─────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  .env is gitignored and should NEVER be committed.
#
#  In Vercel: Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# ── PageSpeed Insights (Phase 2 — CWV tab) ───────────────────
# Free key — console.developers.google.com → Enable "PageSpeed Insights API"
# VITE_ prefix required: this key is read by the React bundle (client-side).
VITE_PSI_KEY=your_psi_api_key_here


# ── Google Service Account (Phase 3 — GSC + GA4) ─────────────
# One service account key file covers both Search Console and GA4.
#
# Setup steps:
#   1. console.cloud.google.com → Create/select project
#   2. IAM & Admin → Service Accounts → Create → download JSON key
#   3. Search Console: Settings → Users and permissions → Add user
#      (paste the client_email from the JSON key; Restricted access is fine)
#   4. GA4: Admin → Property Access Management → Add user
#      (same client_email; Viewer role)
#   5. Copy client_email and private_key from the JSON key below.
#      In Vercel, paste private_key exactly as-is (Vercel handles \n escaping).
#
# NO VITE_ prefix — these are server-side only (Vercel serverless functions).
# NEVER expose service account credentials in the browser bundle.
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"


# ── GA4 Numeric Property ID (per site — in src/data.js) ──────
# The GA4 Data API requires the NUMERIC property ID, not the G-XXXXXX
# measurement ID. Find it in:
#   GA4 → Admin → Property Settings → Property ID (top of page)
# Example: 123456789
#
# Set this directly in src/data.js → SITES → ga4PropertyId field.
# It is not a secret and does not need to be in an env var.
